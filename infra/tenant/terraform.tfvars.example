# Copy to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit this file

# Required
tester_name = "alex"   # Used to name all AWS resources (letters, numbers, hyphens)
ami_id      = ""       # openSUSE Leap Micro 6 aarch64 AMI — find in AWS Marketplace
                       # Search: "openSUSE-Leap-Micro-6" filter by: arm64, your region

# Optional — defaults work for most cases
aws_region    = "us-east-1"
instance_type = "t4g.medium" # ARM64, 4GB RAM — required to run k3s + all services
app_version   = "main"       # Git branch, tag, or SHA for manifest version
image_tag     = "latest"     # Container image tag (use a git SHA to pin a specific build)
key_name      = ""           # EC2 key pair name for SSH (leave empty to skip)
